{
  "openapi": "3.0.3",
  "info": {
    "title": "BillMate API Documentation",
    "description": "Dokumentasi API untuk aplikasi BillMate (Split Bill). Digunakan oleh frontend untuk berinteraksi dengan backend.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/",
      "description": "Server Utama (Otomatis menyesuaikan domain)"
    },
    {
      "url": "http://localhost:8000",
      "description": "Server Lokal (Development)"
    }
  ],
  "paths": {
    "/api/split-bill/calculate": {
      "post": {
        "summary": "Menghitung pembagian tagihan adil (Split Bill) dan menyimpan transaksi",
        "description": "Menerima detail tagihan, nama-nama anggota, item pesanan, dan biaya tambahan (pajak, diskon, extra fee), melakukan perhitungan proporsional, menyimpannya ke database relasional, dan mengembalikan hasil kalkulasi breakdown per anggota.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "restaurantName",
                  "tableNumber",
                  "members",
                  "items"
                ],
                "properties": {
                  "restaurantName": {
                    "type": "string",
                    "maxLength": 255,
                    "example": "Restoran Padang Sederhana"
                  },
                  "tableNumber": {
                    "type": "string",
                    "maxLength": 50,
                    "example": "Meja 12"
                  },
                  "hostName": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Nama host/pemilik room. Jika kosong, default menggunakan anggota pertama.",
                    "example": "Ahmad"
                  },
                  "bankName": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Nama bank tujuan transfer.",
                    "example": "BCA"
                  },
                  "rekening": {
                    "type": "string",
                    "maxLength": 100,
                    "description": "Nomor rekening tujuan transfer.",
                    "example": "1234567890"
                  },
                  "members": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "maxLength": 100
                    },
                    "example": ["Ahmad", "Budi", "Cici"]
                  },
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": [
                        "name",
                        "price",
                        "qty",
                        "user"
                      ],
                      "properties": {
                        "name": {
                          "type": "string",
                          "example": "Nasi Rendang"
                        },
                        "price": {
                          "type": "number",
                          "minimum": 0,
                          "example": 25000
                        },
                        "qty": {
                          "type": "integer",
                          "minimum": 1,
                          "example": 2
                        },
                        "user": {
                          "type": "string",
                          "description": "Nama pengguna/anggota yang memesan item ini. Harus ada dalam daftar 'members'.",
                          "example": "Ahmad"
                        }
                      }
                    },
                    "example": [
                      {
                        "name": "Nasi Rendang",
                        "price": 25000,
                        "qty": 2,
                        "user": "Ahmad"
                      },
                      {
                        "name": "Ayam Pop",
                        "price": 22000,
                        "qty": 1,
                        "user": "Budi"
                      },
                      {
                        "name": "Es Teh Manis",
                        "price": 5000,
                        "qty": 3,
                        "user": "Cici"
                      }
                    ]
                  },
                  "additionalCosts": {
                    "type": "object",
                    "properties": {
                      "taxPercent": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 100,
                        "default": 0,
                        "example": 10
                      },
                      "discount": {
                        "type": "number",
                        "minimum": 0,
                        "default": 0,
                        "example": 5000
                      },
                      "extraFees": {
                        "type": "number",
                        "minimum": 0,
                        "default": 0,
                        "example": 2000
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sukses menghitung dan menyimpan data split bill.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Proses pembagian tagihan adil telah selesai dihitung dan disimpan secara relasional!"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "restaurantName": {
                          "type": "string",
                          "example": "Restoran Padang Sederhana"
                        },
                        "tableNumber": {
                          "type": "string",
                          "example": "Meja 12"
                        },
                        "transactionId": {
                          "type": "string",
                          "example": "QR-20260704-4821"
                        },
                        "date": {
                          "type": "string",
                          "example": "Jul 04, 2026"
                        },
                        "summary": {
                          "type": "object",
                          "properties": {
                            "totalBaseCost": {
                              "type": "number",
                              "example": 77000
                            },
                            "totalTax": {
                              "type": "number",
                              "example": 7700
                            },
                            "totalDiscount": {
                              "type": "number",
                              "example": 5000
                            },
                            "totalExtraFees": {
                              "type": "number",
                              "example": 2000
                            },
                            "grandTotal": {
                              "type": "number",
                              "example": 81700
                            }
                          }
                        },
                        "membersBreakdown": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "memberName": {
                                "type": "string",
                                "example": "Ahmad"
                              },
                              "baseCost": {
                                "type": "number",
                                "example": 50000
                              },
                              "taxShare": {
                                "type": "number",
                                "example": 5000
                              },
                              "discountShare": {
                                "type": "number",
                                "example": 3247
                              },
                              "extraFeeShare": {
                                "type": "number",
                                "example": 667
                              },
                              "grandTotal": {
                                "type": "number",
                                "example": 52420
                              },
                              "orderedItems": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "name": {
                                      "type": "string",
                                      "example": "Nasi Rendang"
                                    },
                                    "price": {
                                      "type": "number",
                                      "example": 25000
                                    },
                                    "qty": {
                                      "type": "integer",
                                      "example": 2
                                    },
                                    "total": {
                                      "type": "number",
                                      "example": 50000
                                    }
                                  }
                                }
                              }
                            }
                          }
                        },
                        "transferInfo": {
                          "type": "object",
                          "properties": {
                            "hostName": {
                              "type": "string",
                              "example": "Ahmad"
                            },
                            "paymentOptions": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "provider": {
                                    "type": "string",
                                    "example": "BCA"
                                  },
                                  "accountNumber": {
                                    "type": "string",
                                    "example": "1234567890"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error (input tidak valid).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Input data tidak valid sesuai format QRoom."
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "example": {
                        "restaurantName": [
                          "The restaurant name field is required."
                        ],
                        "members": [
                          "The members field is required."
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/split-bill/archive": {
      "post": {
        "summary": "Mengarsipkan data sesi split-bill lokal",
        "description": "Mengambil parameter tagihan, memvalidasinya, membuat kode transaksi arsip dengan format `#QR-2026-[HEX]`, dan mengembalikan data arsip untuk frontend.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "restaurantName",
                  "grandTotal",
                  "members"
                ],
                "properties": {
                  "restaurantName": {
                    "type": "string",
                    "maxLength": 255,
                    "example": "Restoran Padang Sederhana"
                  },
                  "grandTotal": {
                    "type": "number",
                    "minimum": 0,
                    "example": 81700
                  },
                  "members": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "maxLength": 100
                    },
                    "example": ["Ahmad", "Budi", "Cici"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sesi berhasil diarsipkan.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Room berhasil dikunci. Sesi ini telah resmi diarsipkan."
                    },
                    "archive": {
                      "type": "object",
                      "properties": {
                        "transactionId": {
                          "type": "string",
                          "example": "#QR-2026-F9AC"
                        },
                        "restaurantName": {
                          "type": "string",
                          "example": "Restoran Padang Sederhana"
                        },
                        "date": {
                          "type": "string",
                          "example": "Jul 04, 2026"
                        },
                        "timestamp": {
                          "type": "integer",
                          "example": 1783222788
                        },
                        "totalAmount": {
                          "type": "number",
                          "example": 81700
                        },
                        "membersCount": {
                          "type": "integer",
                          "example": 3
                        },
                        "membersPreview": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "example": ["Ahmad", "Budi", "Cici"]
                        },
                        "status": {
                          "type": "string",
                          "example": "COMPLETED"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validation Error (input tidak valid).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Gagal mengarsipkan sesi. Struktur data tidak valid."
                    },
                    "errors": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "example": {
                        "grandTotal": [
                          "The grand total field is required."
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
